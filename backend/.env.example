# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave DATABASE_URL empty for local SQLite
# Set to any value to enable PostgreSQL (uses RDS_* vars below)
DATABASE_URL=
# RDS PostgreSQL (used in production / Elastic Beanstalk)
RDS_DB_NAME=hypercore_draw
RDS_USERNAME=postgres
RDS_PASSWORD=
RDS_HOSTNAME=localhost
RDS_PORT=5432

# CORS — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:5173
# For production, add your Amplify domain:
# CORS_ALLOWED_ORIGINS=https://your-app.amplifyapp.com

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Ticket config
TICKET_PRICE_MXN=200
FUNDRAISING_GOAL_MXN=26000
FOLIO_PREFIX=HC
